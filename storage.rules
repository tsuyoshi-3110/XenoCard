rules_version = '2';

// Pageit側の既存Storage Rulesへ、このXenoCard用ルールを統合してください。
// このファイル単体をPageitへデプロイすると、Pageit既存ルールを上書きするため禁止です。

service firebase.storage {
  match /b/{bucket}/o {
    function isGroupAdmin(groupId) {
      return request.auth != null
        && firestore.exists(
          /databases/(default)/documents/xenocardGroups/$(groupId)
        )
        && firestore.get(
          /databases/(default)/documents/xenocardGroups/$(groupId)
        ).data.adminUid == request.auth.uid;
    }

    function isValidImage() {
      return request.resource != null
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }

    match /xenocard/groups/{groupId}/{fileName} {
      allow read: if true;
      allow create, update: if isGroupAdmin(groupId) && isValidImage();
      allow delete: if isGroupAdmin(groupId);
    }

    match /xenocard/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
